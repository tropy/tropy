{
  "name": "tropy",
  "productName": "Tropy",
  "version": "1.18.0-beta.1",
  "private": true,
  "author": "The Tropy Developers and Contributors",
  "description": "Explore your research photos",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://tropy.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/tropy/tropy"
  },
  "bugs": {
    "url": "https://github.com/tropy/tropy/issues"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "main": "lib/main/index.js",
  "type": "module",
  "imports": {
    "#tropy/*.js": "./src/*.js"
  },
  "scripts": {
    "clean": "shx rm -rf coverage doc dist lib npm-debug.log",
    "prerollup": "shx rm -rf lib",
    "rollup": "rollup -c",
    "rollup:dev": "NODE_ENV=development rollup -c",
    "prebuild": "npm run clean && npm run rollup",
    "build": "node scripts/build.js",
    "pack": "node scripts/pack.js",
    "devtools": "electron scripts/devtools.js --data tmp",
    "legal": "node scripts/legal.js",
    "lint": "npm run -s lint:js && npm run -s lint:css",
    "lint:js": "eslint src test scripts res/workers *.js",
    "lint:css": "stylelint 'src/stylesheets/**/*.scss'",
    "log:view": "cat tmp/log/tropy.log | node scripts/log-viewer",
    "log:tail": "tail -q -F tmp/log/tropy.log 2> /dev/null | node scripts/log-viewer.js",
    "log:tail:win": "tail -q -F tmp/log/tropy.log 2> NUL | node scripts/log-viewer.js",
    "start": "electron --app . --env development --data tmp --cache tmp/cache --logs tmp/log",
    "rebuild": "node scripts/rebuild.js",
    "coverage": "c8 -o coverage --reporter=text --reporter=lcov --include='src/**' npm test",
    "test": "spark --no-sandbox",
    "preversion": "npm run lint && npm test",
    "version": "node scripts/version.js && git add res/linux CITATION.cff"
  },
  "spark": {
    "ui": "bdd",
    "timeout": 2000,
    "reporters": [
      "sparks"
    ],
    "mainGlobPatterns": [
      "test/{common,main}/**/*.test.js"
    ],
    "rendererGlobPatterns": [
      "test/*.test.js",
      "test/!(main|support|fixtures)/**/*.test.{js,cjs}"
    ],
    "preload": [
      "test/support/babel.js",
      "test/support/args.js",
      "test/support/log.js",
      "test/support/chai.js",
      "test/support/fixtures.js"
    ],
    "webPreferences": {
      "webSecurity": false
    }
  },
  "devDependencies": {
    "@babel/core": "^7.12.13",
    "@babel/preset-react": "^7.12.13",
    "@electron/notarize": "^3.0.1",
    "@electron/packager": "^19.0.1",
    "@eslint/js": "^9.39.4",
    "@img/sharp-libvips-dev": "1.2.4",
    "@img/sharp-libvips-win32-arm64": "1.2.4",
    "@img/sharp-libvips-win32-ia32": "1.2.4",
    "@img/sharp-libvips-win32-x64": "1.2.4",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/react": "^16.0.0",
    "better-sqlite3": "^12.8.0",
    "c8": "^11.0.0",
    "chai": "^6.0.1",
    "chai-dom": "^1.8.2",
    "detect-libc": "^2.0.1",
    "electron": "^41.0.2",
    "electron-winstaller": "^5.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "minimatch": "^10.0.1",
    "ms": "^2.1.3",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.1.0",
    "prosemirror-test-builder": "^1.0.3",
    "pump": "^3.0.0",
    "react-dnd-test-backend": "^14.0.0",
    "rollup": "^4.34.8",
    "rollup-plugin-copy": "^3.3.0",
    "rollup-plugin-ignore": "^1.0.9",
    "rollup-plugin-license": "^3.0.1",
    "rollup-plugin-natives": "^0.7.2",
    "sass": "^1.64.2",
    "shx": "^0.4.0",
    "spark-chamber": "^0.1.0",
    "split2": "^4.0.0",
    "sqleton": "^4.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.0.0",
    "unzip-crx-3": "^0.2.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6",
    "fsevents": "~2.3.2"
  },
  "dependencies": {
    "@babel/cli": "^7.24.8",
    "@babel/plugin-syntax-import-assertions": "^7.17.12",
    "@inukshuk/exif": "^2.0.0",
    "@koa/router": "^15.1.0",
    "@reduxjs/toolkit": "^2.0.1",
    "@tweenjs/tween.js": "^25.0.0",
    "alto-xml": "^1.0.1",
    "chokidar": "^5.0.0",
    "classnames": "^2.2.6",
    "commander": "^14.0.0",
    "cross-zip": "^4.0.0",
    "edtf": "^4.10.0",
    "generic-pool": "^3.7.1",
    "globals": "^17.0.0",
    "install": "^0.13.0",
    "js-yaml": "^4.0.0",
    "jsonld": "^9.0.0",
    "koa": "^3.0.0",
    "koa-bodyparser": "^4.3.0",
    "lodash.debounce": "^4.0.7",
    "lodash.throttle": "^4.1.1",
    "memoize-one": "^6.0.0",
    "n3": "^2.0.0",
    "nanoid": "^5.0.7",
    "pino": "^10.0.0",
    "pixi-filters": "^6.0.5",
    "pixi.js": "^8.5.2",
    "prosemirror-commands": "^1.1.5",
    "prosemirror-gapcursor": "^1.1.5",
    "prosemirror-history": "^1.1.3",
    "prosemirror-inputrules": "^1.1.3",
    "prosemirror-markdown": "^1.5.1",
    "prosemirror-model": "^1.13.3",
    "prosemirror-schema-basic": "^1.1.2",
    "prosemirror-schema-list": "^1.1.4",
    "prosemirror-state": "^1.3.4",
    "prosemirror-view": "^1.29.0",
    "rdjpgcom": "^1.0.0",
    "react": "^19.2.0",
    "react-dnd": "^14.0.2",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^19.2.0",
    "react-intl": "^8.0.11",
    "react-redux": "^9.1.0",
    "react-transition-group": "^4.4.4",
    "redux-saga": "^1.1.3",
    "sanitize-filename": "^1.6.3",
    "save-dev": "^0.0.1-security",
    "semver": "^7.3.4",
    "sharp": "0.34.5",
    "sqlite3": "^6.0.1",
    "transducers.js": "^0.3.2",
    "uuid": "^13.0.0",
    "winreg": "=1.2.4",
    "write-file-atomic": "^7.0.0"
  }
}
